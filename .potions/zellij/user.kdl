// User Zellij Configuration
// This file is preserved on upgrade — add your custom settings here.
//
// ── LAYOUT SELECTION ────────────────────────────────────────────────────────
// Three layouts are available. Uncomment one line below to activate it.
//
//   default  — tab bar only, no status bar (the shipped default)
//   compact  — tab bar + single-row mode indicator (shows NORMAL / RESIZE / etc.)
//   minimal  — tab bar only (same as default, explicit alias)
//
// default_layout "compact"
// default_layout "minimal"
//
// ── PANE NAVIGATION ─────────────────────────────────────────────────────────
// Alt+h/j/k/l  move focus between panes (no prefix needed)
// Alt+arrows   same, for terminals where Alt+hjkl is not forwarded (e.g. Termux)
//
// Ctrl+a then h/j/k/l  also works (tmux-prefix style, unchanged)
//
// ── macOS NOTES ─────────────────────────────────────────────────────────────
// The prefix key is Ctrl+a (not Cmd+A). On macOS, Cmd+A triggers "Select All"
// in the terminal — Zellij never sees it. Use the Ctrl key (bottom-left corner),
// not the ⌘ Cmd key (next to spacebar).
//
// Alt+d/t/w/n/p/Enter are bound in config.kdl and mirror macOS Cmd conventions:
//   Alt+d → split right  (Cmd+D in iTerm2/Warp/Ghostty)
//   Alt+t → new tab      (Cmd+T)
//   Alt+w → close pane   (Cmd+W)
//   Alt+n → next tab     (Cmd+Shift+])
//   Alt+p → prev tab     (Cmd+Shift+[)
//   Alt+Enter → fullscreen (Cmd+Return)
//
// macOS users can restore Cmd muscle memory by forwarding Cmd+<key> → Alt+<key>
// in their terminal. One-time setup per terminal:
//   iTerm2:    Profiles → Keys → Option Key: "Esc+"
//              then add Key Mappings: Cmd+D → Send Escape Sequence "d"  (etc.)
//   Ghostty:   keybind = cmd+d=send_key:alt+d  (in ghostty.conf, one line per key)
//   Kitty:     map cmd+d send_key alt+d  (in kitty.conf, one line per key)
//   Terminal.app: Preferences → Profiles → Keyboard → "Use Option as Meta Key"
//                 then press Option+<key> instead of Cmd+<key>
// See ~/.potions/terminal-setup/TERMINAL_SETUP.md for full per-terminal instructions.
//
// ── CUSTOM KEYBINDINGS ──────────────────────────────────────────────────────
// Example: add a binding in tmux mode
//   keybinds {
//       tmux {
//           bind "m" { NewPane "Right"; SwitchToMode "Normal"; }
//       }
//   }
//
// ── THEME ────────────────────────────────────────────────────────────────────
// Example: switch to a different theme
//   theme "dracula"
//
// Note: Zellij KDL config does not support a "source" directive.
// To load a fully custom config, set ZELLIJ_CONFIG_DIR to a directory
// containing your own config.kdl.
