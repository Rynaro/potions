# Ignore everything by default
*

# Allow essential docs
!README.md
!AGENTS.md
!docs
!docs/
!docs/*.md

# Assets
!assets
!assets/
!assets/images/
!assets/images/*.jpg

# Allow the Installer and Env
!.zshenv
!install.sh
!drink.sh
!upgrade.sh
!uninstall.sh
!migrate.sh
!test.sh
!.version
!.checksums

# Allow Installer packs
!packages
!packages/
!packages/accessories.sh
!packages/common/
!packages/common/*.sh
!packages/macos/
!packages/macos/*.sh
!packages/wsl/
!packages/wsl/*.sh
!packages/termux/
!packages/termux/*.sh
!packages/debian/
!packages/debian/*.sh
!packages/fedora/
!packages/fedora/*.sh

# Plugin Management System
!plugins.sh
!plugins/
!plugins/*.sh
!plugins/*.md

# Plugin core modules
!plugins/core/
!plugins/core/*.sh

# Plugin registry
!plugins/registry/
!plugins/registry/*.txt
!plugins/registry/*.sh

# Plugin templates
!plugins/templates/
!plugins/templates/*.sh
!plugins/templates/*.json
!plugins/templates/*.md

# Plugin tests
!plugins/tests/
!plugins/tests/*.sh

# Allow the .potions directory and its contents
!.potions
!.potions/
!.potions/.zshrc
!.potions/.zsh_aliases
!.potions/.zsh_plugins.txt
!.potions/.zsh
!.potions/.zsh/
!.potions/.zsh/contrib
!.potions/.zsh/contrib/*

# Allow Potions documentation
!.potions/KEYMAPS.md

# Allow user config directory
!.potions/config
!.potions/config/
!.potions/config/*.zsh

# Allow terminal setup guides
!.potions/terminal-setup
!.potions/terminal-setup/
!.potions/terminal-setup/*

# Allow NVim config files
!.potions/nvim
!.potions/nvim/
!.potions/nvim/init.vim
!.potions/nvim/user.vim

# Allow Zellij config files
!.potions/zellij
!.potions/zellij/
!.potions/zellij/config.kdl
!.potions/zellij/user.kdl
!.potions/zellij/layouts
!.potions/zellij/layouts/
!.potions/zellij/layouts/*.kdl
!.potions/zellij/CHEATSHEET.md

# Allow Potions CLI
!.potions/bin
!.potions/bin/
!.potions/bin/potions

# Allow help library
!.potions/lib
!.potions/lib/
!.potions/lib/help.sh

# Allow theme system library (resolver, state, registry, generator, manager)
!.potions/lib/theme
!.potions/lib/theme/
!.potions/lib/theme/*.sh

# Allow terminal-emulator support library (Ghostty/Termux setup manager)
!.potions/lib/terminal
!.potions/lib/terminal/
!.potions/lib/terminal/*.sh

# Allow built-in themes: DTCG token sources, compiled .theme files, manifests
!.potions/themes
!.potions/themes/
!.potions/themes/*
!.potions/themes/*/
!.potions/themes/*/*

# Allow Potionfile template
!.potions/Potionfile.template

# Git configuration files
!.gitconfig
!.gitignore
!.gitexcludes


# Vim configuration files
!.vim
!.vim/
!.vim/*
!.vimrc

# Ignore Vim swapfiles
.vim/.netrwhist
.vim/plugged
.vim/.*.swp
.vim/*/.*.swp
.vim/*/*/.*.swp
.vim/*/*/*/.*.swp

# Local tools and scripts
!bin
!bin/

# Development scripts
!scripts
!scripts/
!scripts/*.sh

# GitHub Actions workflows
!.github
!.github/
!.github/workflows
!.github/workflows/*.yml

# Screen configuration files
!.screenrc

# <!-- eidolon:gitignore start -->
# Managed by eidolons. Recreated by `eidolons sync`. Do not edit between markers.
/.eidolons/*
!/.eidolons/cortex/
!/.eidolons/cortex/**
!/.eidolons/harness/
!/.eidolons/harness/manifest.json
# <!-- eidolon:gitignore end -->
.atlas/
